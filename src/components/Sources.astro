---
interface Source {
  label: string;
  url?: string;
}
interface Props {
  sources?: Source[];
  lastUpdated?: Date;
}
const { sources = [], lastUpdated } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });
---

{(sources.length > 0 || lastUpdated) && (
  <section class="sources">
    {sources.length > 0 && (
      <>
        <h2>Sources &amp; further reading</h2>
        <ul>
          {sources.map((s) => (
            <li>{s.url ? <a href={s.url} rel="noopener">{s.label}</a> : s.label}</li>
          ))}
        </ul>
      </>
    )}
    {lastUpdated && <p class="topic-meta">Last reviewed: {fmt(lastUpdated)}</p>}
  </section>
)}
