---
import { withBase } from '../lib/url';

const { pathname } = Astro.url;
// Normalise for comparison (strip base + trailing slash)
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = pathname.replace(base, '').replace(/\/$/, '') || '/';

const links = [
  { href: withBase('/'), label: 'Home', match: '/' },
  { href: withBase('regions/'), label: 'Regions', match: '/regions' },
  { href: withBase('about/'), label: 'About', match: '/about' },
  { href: withBase('contribute/'), label: 'Contribute', match: '/contribute' },
];

const isCurrent = (match: string) =>
  match === '/' ? path === '/' : path === match || path.startsWith(match + '/');
---

<nav class="site-nav" aria-label="Primary">
  <div class="container inner">
    <a class="brand" href={withBase('/')}>
      <span><span class="k">Eti</span>Kette</span>
      <span class="tag">Dining etiquette of India</span>
    </a>
    <ul class="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} aria-current={isCurrent(l.match) ? 'page' : undefined}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
