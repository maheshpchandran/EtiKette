---
interface Props {
  href?: string;
  icon?: string;
  title: string;
  summary: string;
  soon?: boolean;
}
const { href, icon = '🍃', title, summary, soon = false } = Astro.props;
const Tag = soon || !href ? 'div' : 'a';
---

<Tag class={`card${soon ? ' disabled' : ''}`} href={soon ? undefined : href}>
  <div class="icon" aria-hidden="true">{icon}</div>
  <h3>{title}</h3>
  <p>{summary}</p>
  {soon && <span class="soon">Coming soon</span>}
</Tag>
