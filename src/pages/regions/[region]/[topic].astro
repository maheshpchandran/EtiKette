---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Sources from '../../../components/Sources.astro';
import { getRegion } from '../../../data/regions';
import { withBase, regionHref, topicHref } from '../../../lib/url';

export async function getStaticPaths() {
  const entries = await getCollection(
    'regions',
    (e) => !e.data.draft && !e.id.endsWith('/overview')
  );
  return entries.map((e) => {
    const [region, ...rest] = e.id.split('/');
    return { params: { region, topic: rest.join('/') }, props: { entry: e } };
  });
}

const { entry } = Astro.props;
const { region } = Astro.params;
const meta = getRegion(region)!;
const { Content } = await render(entry);

// Previous / next within the same region (by order, excluding the overview).
const siblings = (
  await getCollection(
    'regions',
    (e) => e.id.startsWith(`${region}/`) && e.id !== `${region}/overview` && !e.data.draft
  )
).sort((a, b) => a.data.order - b.data.order);
const idx = siblings.findIndex((e) => e.id === entry.id);
const prev = siblings[idx - 1];
const next = siblings[idx + 1];
const slugOf = (e: (typeof siblings)[number]) => e.id.split('/').slice(1).join('/');
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <div class="container">
    <Breadcrumbs
      items={[
        { label: 'Home', href: withBase('/') },
        { label: 'Regions', href: withBase('regions/') },
        { label: meta.name, href: regionHref(region) },
        { label: entry.data.title },
      ]}
    />

    <header class="topic-head prose">
      <h1>{entry.data.title}</h1>
      <p class="summary">{entry.data.summary}</p>
    </header>

    <article class="prose">
      <Content />
    </article>

    <div class="prose">
      <Sources sources={entry.data.sources} lastUpdated={entry.data.lastUpdated} />
    </div>

    <nav class="topic-nav prose" aria-label="More guides in this region">
      {prev ? (
        <a href={topicHref(region, slugOf(prev))}>
          <span class="dir">← Previous</span>
          {prev.data.title}
        </a>
      ) : (
        <a href={regionHref(region)}>
          <span class="dir">←</span>
          All {meta.name} guides
        </a>
      )}
      {next && (
        <a class="next" href={topicHref(region, slugOf(next))}>
          <span class="dir">Next →</span>
          {next.data.title}
        </a>
      )}
    </nav>
  </div>
</BaseLayout>
