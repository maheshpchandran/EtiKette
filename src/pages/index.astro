---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicCard from '../components/TopicCard.astro';
import { regions, publishedRegions } from '../data/regions';
import { regionHref, withBase } from '../lib/url';
---

<BaseLayout title="EtiKette">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Dining etiquette of India</p>
      <h1>How India eats — region by region.</h1>
      <p class="lead">
        India has no single table manner. EtiKette documents how people actually
        eat, serve, and celebrate food across the country — the layout of a
        banana-leaf sadya, the etiquette of eating by hand, who gets served
        first — and flags where a beloved tradition could be made more hygienic.
      </p>
      <div class="cta-row">
        <a class="btn" href={regionHref('kerala')}>Start with Kerala 🌴</a>
        <a class="btn secondary" href={withBase('about/')}>What is EtiKette?</a>
      </div>
    </div>
  </section>

  <div class="container">
    <section>
      <h2>Regions</h2>
      <p class="prose">
        We’re building this one region at a time, with care and local input.
        Kerala is live; others are on the way.
      </p>
      <ul class="card-grid">
        {regions.map((r) => (
          <TopicCard
            href={r.status === 'published' ? regionHref(r.slug) : undefined}
            icon={r.emoji}
            title={r.name}
            summary={r.blurb}
            soon={r.status === 'planned'}
          />
        ))}
      </ul>
    </section>

    <section>
      <h2>What you’ll find on each guide</h2>
      <div class="prose">
        <p>Every region is broken into the same practical chapters, so once you
          learn one you know how to read the next:</p>
        <ul>
          <li><strong>The feast</strong> — how a celebratory meal is laid out and eaten.</li>
          <li><strong>Eating by hand</strong> — the technique, and which hand does what.</li>
          <li><strong>Serving &amp; hosting</strong> — who is served first, and how to politely say “enough”.</li>
          <li><strong>Hygiene</strong> — traditional practices, the real risks, and safer alternatives.</li>
          <li><strong>Festivals &amp; occasions, do’s &amp; don’ts, and a glossary.</strong></li>
        </ul>
      </div>
    </section>

    <section class="prose">
      <h2>Help build it</h2>
      <p>
        EtiKette is open source. If you know a regional custom, can correct a
        detail, or want to add a whole new region, contributions are welcome —
        no coding required, just Markdown.
      </p>
      <p><a class="btn" href={withBase('contribute/')}>How to contribute</a></p>
    </section>
  </div>
</BaseLayout>
